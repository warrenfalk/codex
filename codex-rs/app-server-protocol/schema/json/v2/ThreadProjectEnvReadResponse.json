{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not guaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set using [AbsolutePathBufGuard::new]. If no base path is set, the deserialization will fail unless the path being deserialized is already absolute.",
      "type": "string"
    },
    "ThreadProjectEnvState": {
      "enum": [
        "disabled",
        "none",
        "building",
        "ready",
        "failed"
      ],
      "type": "string"
    },
    "ThreadProjectEnvStatus": {
      "properties": {
        "cwd": {
          "anyOf": [
            {
              "$ref": "#/definitions/AbsolutePathBuf"
            },
            {
              "type": "null"
            }
          ]
        },
        "envrcPath": {
          "anyOf": [
            {
              "$ref": "#/definitions/AbsolutePathBuf"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/ThreadProjectEnvState"
        },
        "threadId": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "watchedInputCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "status",
        "threadId",
        "updatedAt",
        "watchedInputCount"
      ],
      "type": "object"
    }
  },
  "properties": {
    "projectEnv": {
      "$ref": "#/definitions/ThreadProjectEnvStatus"
    }
  },
  "required": [
    "projectEnv"
  ],
  "title": "ThreadProjectEnvReadResponse",
  "type": "object"
}